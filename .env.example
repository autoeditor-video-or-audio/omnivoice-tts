# .env file paired with docker-compose.gpu.prod.yml
# Copy to .env and edit on the GPU host.

# GHCR image tag. Choices:
#   latest-gpu        (sdpa, lean *-base-* CUDA layer)
#   latest-gpu-flash  (flash-attn 2.8.3 prebuilt wheel; recommended on RTX 4060+)
OMNIVOICE_IMAGE_TAG=latest-gpu-flash

# Listen port on host (8007 chosen to coexist with qwen3-tts forks on 8005)
OMNIVOICE_PORT=8007

# Model checkpoint
OMNIVOICE_MODEL=k2-fsa/OmniVoice

# Precision
OMNIVOICE_DTYPE=float16

# CUDA device
OMNIVOICE_DEVICE=cuda:0

# Diffusion steps (32 default, 16 faster)
OMNIVOICE_NUM_STEP=32

# Defaults match upstream's gradio demo combo
# (`omnivoice/cli/demo.py:187`). Earlier iterations of the fork
# overrode chunking + sampling + postprocess; isolated REPL tests on
# PT-BR clones showed those overrides were chases that each broke
# something else (low chunking dropped the first word, greedy
# sampling didn't fix drift on its own). The demo combo reproduces
# the upstream Gradio UI's quality on PT-BR clones.
OMNIVOICE_GUIDANCE_SCALE=2.0
OMNIVOICE_DENOISE=true
OMNIVOICE_PREPROCESS_PROMPT=true
OMNIVOICE_POSTPROCESS_OUTPUT=true

# Voice-clone validation
OMNIVOICE_CLONE_MIN_SECONDS=3
OMNIVOICE_CLONE_STORE_MAX_SECONDS=15

# Verbosity
OMNIVOICE_LOG_LEVEL=INFO
