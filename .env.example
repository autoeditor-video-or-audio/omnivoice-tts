# .env file paired with docker-compose.gpu.prod.yml
# Copy to .env and edit on the GPU host.

# GHCR image tag. Choices:
#   latest-gpu        (sdpa, lean *-base-* CUDA layer)
#   latest-gpu-flash  (flash-attn 2.8.3 prebuilt wheel; recommended on RTX 4060+)
OMNIVOICE_IMAGE_TAG=latest-gpu-flash

# Listen port on host (8007 chosen to coexist with qwen3-tts forks on 8005)
OMNIVOICE_PORT=8007

# Model checkpoint
OMNIVOICE_MODEL=k2-fsa/OmniVoice

# Precision
OMNIVOICE_DTYPE=float16

# CUDA device
OMNIVOICE_DEVICE=cuda:0

# Diffusion steps (32 default, 16 faster)
OMNIVOICE_NUM_STEP=32

# Sampling temperatures. Upstream defaults: position=5.0, class=0.0.
# This fork defaults BOTH to 0.0 (greedy = deterministic) so the
# cloned voice does not drift across consecutive synth requests on
# PT-BR. Increase position_temperature if you want stylistic variance
# in EN/ZH (upstream's trained languages); leave at 0.0 for PT-BR.
OMNIVOICE_POSITION_TEMPERATURE=0.0
OMNIVOICE_CLASS_TEMPERATURE=0.0

# Per-request PyTorch RNG seed. Default 0 so every call starts from
# the same state. Set to a NEGATIVE number to disable reseeding (lets
# RNG advance naturally — needed if you want stochastic generation
# with position_temperature>0).
OMNIVOICE_REQUEST_SEED=0

# Chunking. Empirical PT-BR finding: upstream's single-shot path
# (chunking off) holds the cloned voice for one word, then drifts.
# `_generate_chunked` re-conditions the reference at every chunk
# boundary, anchoring the clone for the whole utterance.
# Default to 5s threshold + 3s chunks so any sentence longer than
# ~5s gets chunked and stays on-voice. Operators running EN/ZH where
# the single-shot path was stable can raise these (the upstream
# defaults are 30.0 / 15.0).
OMNIVOICE_AUDIO_CHUNK_THRESHOLD=5.0
OMNIVOICE_AUDIO_CHUNK_DURATION=3.0

# Voice-clone validation
OMNIVOICE_CLONE_MIN_SECONDS=3
OMNIVOICE_CLONE_STORE_MAX_SECONDS=15

# Verbosity
OMNIVOICE_LOG_LEVEL=INFO
